SMARTCAM_VERSION=1.0.0
DEVICE_NAME=SmartCam01
# ======================================================
# SmartCam Enterprise Environment Configuration
# ======================================================

# ======================
# TELEGRAM CONFIG
# ======================
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_CHAT_ID
ALERT_COOLDOWN_SECONDS=300
TELEGRAM_ENABLED=true
TELEGRAM_ESCALATION_THRESHOLD=3

# ======================
# STREAM SETTINGS
# ======================
STREAM_NAME=live
MIN_BITRATE_MBPS=1
MAX_RECORDING_AGE=15
GUARD_TIMEOUT_SECONDS=60
GUARD_HEARTBEAT_FILE=/var/lib/smartcam/guard_heartbeat

# ======================
# RAM THRESHOLDS (MB)
# ======================
MAX_RAM_WARN=150
MAX_RAM_CRITICAL=80

# ======================
# DISK PROTECTION
# ======================
MIN_FREE_MB=2048
MAX_DISK_PERCENT=85
SD_CLEANUP_ESCALATION_THRESHOLD=3
SD_WEAR_REDUCTION_MODE=true

# ======================
# TEMPERATURE
# ======================
MAX_TEMP=75

# ======================
# HEALTH ENGINE WEIGHTS
# ======================
HEALTH_STREAM_WEIGHT=30
HEALTH_RECORDING_WEIGHT=20
HEALTH_DISK_WEIGHT=15
HEALTH_TEMP_WEIGHT=10
HEALTH_RAM_WEIGHT=10
HEALTH_SERVICE_WEIGHT=15

# ======================
# SMB BACKUP CONFIG (Optional)
# ======================
SMB_ENABLED=true
SMB_SHARE=//192.168.1.100/smartcam-backup
SMB_USER=backupuser
SMB_PASS=backuppassword
SMB_MOUNT=/mnt/smartcam-backup

# ======================
# BACKUP SETTINGS
# ======================
BACKUP_KEEP_LOCAL=7
BACKUP_VERIFY_CHECKSUM=true
BACKUP_ENABLED=true
BACKUP_FAILURE_ESCALATION_THRESHOLD=3
BACKUP_HEALTH_FILE=/var/lib/smartcam/backup_health.json
BACKUP_MIN_FREE_MB=1024

# ======================
# SNAPSHOT / HEALTH FILE
# ======================
SNAPSHOT_FILE=/var/lib/smartcam/health_snapshot.json
BOOT_HISTORY_FILE=/var/lib/smartcam/boot_history.json
BOOT_COUNTER_FILE=/var/lib/smartcam/boot_counter
BOOT_LOOP_THRESHOLD=5
BOOT_LOOP_WINDOW_MIN=10

# ======================
# STATIC IP SETTINGS (Installer Use)
# ======================
STATIC_IP=
GATEWAY=
DNS=
INTERFACE=

# ======================
# SAFETY CONTROLS
# ======================
ENABLE_SD_PROTECTION=true
ENABLE_GUARD=true
ENABLE_BACKUP=true
ENABLE_BOOT_NOTIFY=true
ENABLE_SNAPSHOT=true
ENABLE_PREDICTIVE_WARNINGS=true


# ======================
# WEB AUTHENTICATION
# ======================
# IMPORTANT: Change these before production use
SC_USER=smartcamadmin
SC_PASS=CHANGE_THIS_STRONG_PASSWORD

# Session security
SESSION_TIMEOUT_MIN=60
COOKIE_SECURE=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=15